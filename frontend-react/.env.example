# Не используйте `VITE_API_URL=http://localhost/api` — это порт 80, обычно пусто и будет ERR_CONNECTION_REFUSED.
# Для `npm run dev` оставьте VITE_API_URL не заданным или `/api`.
# Для продакшена на CDN без своего nginx: VITE_API_URL=https://api.example.com/api
#
# VITE_API_URL=
#
# Только для vite dev: куда проксировать /api и /sanctum (nginx Laravel на хосте)
VITE_PROXY_TARGET=http://localhost:8080

# --- Docker Compose (этот репозиторий, docker-compose.yml) ---
# FRONTEND_PORT=3000
# Переопределить при необходимости: VITE_API_URL=https://api.example.com/api
#
# На бэкенде Laravel: FRONTEND_URL должен совпадать с публичным URL этого SPA (письма: reset-password, invite).
