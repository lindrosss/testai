# Подхватывается `docker compose` из каталога backend/ (рядом с docker-compose.yml).
# Скопируйте в `.env` при необходимости сменить порты и образ фронта.

# Репозиторий должен содержать рядом с `backend/` каталог `frontend-react/` (монорепо / два клона в одной родительской папке).

# Порт HTTP edge nginx (vameo-nginx) на хосте. Внутри контейнера всегда слушается 80.
# Рекомендация для VPS: оставить 8080 и повесить системный nginx на 80 → см. deploy/nginx-vameo-docker-proxy.conf
# Альтернатива без хостового nginx: только если порт 80 свободен — поставьте 80 здесь.
VAMEO_NGINX_HTTP_PORT=8080

# Порт SPA на хосте (прямой доступ к контейнеру фронта; основной вход — через edge nginx).
FRONTEND_PORT=3000

# Опционально: готовый образ вместо build (CI). Пример: ghcr.io/org/frontend-vameo:latest
# FRONTEND_IMAGE=ghcr.io/lindrosss/frontend-vameo:latest
