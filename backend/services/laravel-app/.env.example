APP_NAME=Vameo
APP_ENV=local
APP_KEY=
# Обязателен для tymon/jwt-auth (инвайты). В docker-compose для laravel-app задайте JWT_SECRET.
JWT_SECRET=
APP_DEBUG=true
# Публичный URL API (в Docker за nginx обычно http://localhost:8080; см. VAMEO_NGINX_HTTP_PORT в backend/docker-compose).
APP_URL=http://localhost:8080

# Logging: daily driver rotates files and prunes old files (see config/logging.php channels.daily.days).
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DAILY_DAYS=14
LOG_LEVEL=debug

FRONTEND_URL=http://localhost:5173

# Comma-separated origins для React (Vite :5173, Docker SPA :3000) и 127.0.0.1.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:3000,127.0.0.1,127.0.0.1:5173,127.0.0.1:3000

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=vameo_db
DB_USERNAME=vameo_user
DB_PASSWORD=secret

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CLIENT=predis

SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@vameo.com
MAIL_FROM_NAME=Vameo

# Temporary SMTP (e.g. Yandex) for local testing:
# - Create an app password in Yandex ID (Security -> App passwords)
# - Then set MAIL_MAILER=smtp and fill values below.
# MAIL_HOST=smtp.yandex.ru
# MAIL_PORT=465
# MAIL_SCHEME=smtps
# MAIL_USERNAME=lindrosss88@yandex.ru
# MAIL_PASSWORD=your-app-password-here
# MAIL_EHLO_DOMAIN=localhost

# Internal API (Go worker -> POST /api/internal/email/send). Must match worker INTERNAL_API_KEY.
INTERNAL_API_KEY=your-secret-api-key-change-me
